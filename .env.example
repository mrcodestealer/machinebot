# ================= Lark App (machinebot) =================
# Subscription mode: Receive events through a persistent connection (long connection / WebSocket).
LARK_EVENT_MODE=websocket
APP_ID=<your-app-id>
APP_SECRET=<your-value-here>
VERIFICATION_TOKEN=<your-value-here>
# 'lark' for Lark international (open.larksuite.com); 'feishu' for China Feishu.
LARK_DOMAIN=lark
# Flask diag + /wm dashboard port (avoid clashing with osedutybot/logcreditbot on 5000).
PORT=5010
# 0.0.0.0 to reach the /wm dashboard from other hosts; default 127.0.0.1.
# FLASK_BIND_HOST=0.0.0.0

# Leave blank to auto-resolve from Lark at startup (needed for group @mention detection).
BOT_OPEN_ID=

# systemd unit restarted by /deploy (git pull + restart).
MACHINEBOT_SERVICE=machine
# Comma-separated open_ids allowed to /deploy; empty = anyone who can address the bot.
DEPLOY_ALLOWED_OPEN_IDS=

# ================= Playwright =================
BOT_PLAYWRIGHT_HEADLESS=1
# Warm pools hold logged-in Chromiums (faster, heavier). Keep 0 on CPU-only hosts.
PROD_WARM_POOL=0
WEBMACHINE_WARM_POOL=0
THIRD_HTTP_WARM_POOL=0

# ================= Machine dashboard + scrape loop (webmachine.py) =================
# webmachine's loop min is 60s (osedutybot's webapp used 30s).
WEBMACHINE_SCRAPE_INTERVAL_SEC=60
WEBMACHINE_URL_PREFIX=/wm
# WEBMACHINE_SITES=
# WEBMACHINE_DEPLOYMENTS=prod,qat,uat
WEBMACHINE_PUBLIC_BASE_URL=<https://your-tunnel-or-host/wm/>

# QAT/UAT osmslot logins used by the scrape + prod-batch engine.
# WEBMACHINE_OSMSLOT_USER=  (not set in osedutybot/.env)
# WEBMACHINE_OSMSLOT_PASSWORD=  (not set in osedutybot/.env)
# OSMSLOT_ADMIN_USER=  (not set in osedutybot/.env)
# OSMSLOT_ADMIN_PASSWORD=  (not set in osedutybot/.env)

# ================= EGM backend logins (prod-batch set/unset via checkcredit routing) =================
NP_BACKEND_USER=<your-value-here>
NP_BACKEND_PASSWORD=<your-value-here>
DHS_BACKEND_USER=<your-value-here>
DHS_BACKEND_PASSWORD=<your-value-here>
NCH_BACKEND_USER=<your-value-here>
NCH_BACKEND_PASSWORD=<your-value-here>
TBP_BACKEND_USER=<your-value-here>
TBP_BACKEND_PASSWORD=<your-value-here>
CP_BACKEND_USER=<your-value-here>
CP_BACKEND_PASSWORD=<your-value-here>
TBR_BACKEND_USER=<your-value-here>
TBR_BACKEND_PASSWORD=<your-value-here>
MDR_BACKEND_USER=<your-value-here>
MDR_BACKEND_PASSWORD=<your-value-here>
WF_BACKEND_USER=<your-value-here>
WF_BACKEND_PASSWORD=<your-value-here>

